nextflow_pipeline {

    name "Test nf-core-utils notification system"
    script "./main.nf"

    test("Notification system") {

        then {
            assert workflow.success
            def normalizedOutput = filterNextflowOutput(workflow.stdout + workflow.stderr, keepAnsi: true).flatten().findAll { it instanceof String }.collect { line ->
                line
                    .replaceAll(/https:\/\/cloud\.seqera\.io\/user\/[^\/\s]+\/watch\/[A-Za-z0-9]+/, 'https://cloud.seqera.io/user/[USER]/watch/[TRACE_ID]')
                    .replaceAll(/https:\/\/api\.cloud\.seqera\.io\/trace\/[A-Za-z0-9]+\/complete/, 'https://api.cloud.seqera.io/trace/[TRACE_ID]/complete')
            }
            assert snapshot(normalizedOutput).match()
        }
    }
}
